{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Router Definition",
  "description": "Schema for routers/<id>/router.yaml",
  "type": "object",
  "required": ["name", "strategy"],
  "properties": {
    "name": {
      "type": "string",
      "description": "Human-readable router name"
    },
    "description": {
      "type": "string",
      "description": "What this router decides"
    },
    "strategy": {
      "type": "string",
      "enum": ["llm", "deterministic"],
      "description": "Decision mechanism"
    },
    "provider": {
      "type": "string",
      "enum": ["openai", "anthropic"],
      "description": "LLM provider. Auto-detected from model name if omitted."
    },
    "model": {
      "type": "string",
      "description": "LLM model identifier (e.g., gpt-4.1-mini, claude-sonnet-4-5-20241022)"
    },
    "temperature": {
      "type": "number",
      "minimum": 0,
      "maximum": 2,
      "description": "Sampling temperature"
    },
    "handler": {
      "type": "string",
      "description": "Deterministic handler function name (strategy: deterministic only)"
    },
    "input": {
      "type": "object",
      "description": "Input parameter definitions",
      "additionalProperties": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["base64", "string", "number", "boolean", "object"]
          },
          "required": {
            "type": "boolean",
            "default": true
          }
        }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "strategy": { "const": "llm" } } },
      "then": { "required": ["model"] }
    },
    {
      "if": { "properties": { "strategy": { "const": "deterministic" } } },
      "then": { "required": ["handler"] }
    }
  ]
}
